# EduTrack — environment variables.
# Copy this file to `.env` and fill in your real EduPage password.
# .env is gitignored so your password never goes to GitHub.
#
# Subdomain comes from your EduPage URL — for https://quantumstem.edupage.org/
# the subdomain is "quantumstem".

EDUPAGE_USERNAME=a.abenov26@quantum.edu.kz
EDUPAGE_PASSWORD=your-edupage-password-here
EDUPAGE_SUBDOMAIN=quantumstem

# Optional — display name shown in the dashboard header.
EDUPAGE_STUDENT_NAME=Aidyn Abenov
